{
  "name": "edams-web",
  "version": "1.0.0",
  "description": "企业数据资产管理系统前端应用",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "umi dev",
    "dev:dev": "MOCK=none UMI_ENV=dev umi dev",
    "dev:test": "MOCK=none UMI_ENV=test umi dev",
    "build": "umi build",
    "build:dev": "UMI_ENV=dev umi build",
    "build:test": "UMI_ENV=test umi build",
    "build:prod": "UMI_ENV=prod umi build",
    "postinstall": "umi setup",
    "setup": "umi setup",
    "start": "npm run dev",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx src --fix",
    "prettier": "prettier --write \"src/**/*.{ts,tsx,json,css,less}\"",
    "analyze": "ANALYZE=1 umi build"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@ant-design/pro-components": "^2.6.0",
    "@umijs/max": "^4.2.0",
    "ahooks": "^3.8.0",
    "antd": "^5.15.0",
    "axios": "^1.6.8",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "i18next": "^23.10.1",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.22.3",
    "umi": "^4.2.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@ant-design/compatible": "^5.1.2",
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@umijs/fabric": "^2.14.1",
    "@umijs/lint": "^4.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "terser-webpack-plugin": "^5.3.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "webpack-bundle-analyzer": "^4.10.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
