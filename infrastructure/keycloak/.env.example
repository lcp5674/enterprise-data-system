# Keycloak Environment Variables Template
# Copy this file to .env and fill in the values

# ===========================================
# Keycloak Admin Configuration
# ===========================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# ===========================================
# Database Configuration
# ===========================================
KEYCLOAK_DB_PASSWORD=change_me_in_production

# ===========================================
# Client Secrets
# ===========================================
KEYCLOAK_CLIENT_SECRET=change_me_in_production
KEYCLOAK_BACKEND_SECRET=change_me_in_production

# ===========================================
# Host Configuration
# ===========================================
# Set to true in production with HTTPS
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_HOSTNAME_STRICT_HTTPS=false
KEYCLOAK_HTTP_ENABLED=true
KEYCLOAK_HTTP_PORT=8180
KEYCLOAK_HTTPS_PORT=8543

# ===========================================
# Metrics (Optional)
# ===========================================
KEYCLOAK_METRICS_ENABLED=true

# ===========================================
# SMTP Configuration (Optional)
# ===========================================
# MAIL_HOST=smtp.company.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@company.com
# MAIL_PASSWORD=your_password
# MAIL_FROM=EDAMS <noreply@company.com>

# ===========================================
# EDAMS Application Environment
# ===========================================
# Enable/Disable Keycloak SSO
KEYCLOAK_ENABLED=true

# Keycloak Server URLs
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/edams
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/edams/protocol/openid-connect/certs
KEYCLOAK_TOKEN_URI=http://localhost:8180/realms/edams/protocol/openid-connect/token
KEYCLOAK_AUTHORIZATION_URI=http://localhost:8180/realms/edams/protocol/openid-connect/auth
KEYCLOAK_USER_INFO_URI=http://localhost:8180/realms/edams/protocol/openid-connect/userinfo

# Keycloak Client Configuration
KEYCLOAK_CLIENT_ID=edams-client
KEYCLOAK_REALM=edams

# Multi-tenancy (Optional)
KEYCLOAK_MULTI_TENANCY_ENABLED=false

# ===========================================
# Production Settings (HTTPS)
# ===========================================
# Uncomment and configure for production
# KEYCLOAK_HOSTNAME=keycloak.company.com
# KEYCLOAK_HOSTNAME_STRICT=true
# KEYCLOAK_HOSTNAME_STRICT_HTTPS=true
# KEYCLOAK_HTTP_ENABLED=false
# KEYCLOAK_ISSUER_URI=https://keycloak.company.com/realms/edams
# KEYCLOAK_JWK_SET_URI=https://keycloak.company.com/realms/edams/protocol/openid-connect/certs
