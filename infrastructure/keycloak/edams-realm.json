{
  "realm": "edams",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "roles": {
    "realm": [
      {
        "name": "edams-admin",
        "description": "EDAMS系统管理员",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "edams-user",
        "description": "EDAMS普通用户",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "edams-data-steward",
        "description": "EDAMS数据治理员",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "edams-auditor",
        "description": "EDAMS审计员",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "offline_access",
        "description": "${role_offline-access}",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "uma_authorization",
        "description": "${role_uma_authorization}",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {
      "edams-client": [
        {
          "name": "admin",
          "description": "EDAMS管理员权限",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "user",
          "description": "EDAMS用户权限",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "data-steward",
          "description": "数据治理权限",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "viewer",
          "description": "只读权限",
          "composite": false,
          "clientRole": true
        }
      ]
    }
  },
  "defaultRoles": ["edams-user"],
  "defaultGroups": ["/edams-users"],
  "groups": [
    {
      "name": "/edams-admins",
      "path": "/edams-admins",
      "subGroups": [],
      "attributes": {},
      "realmRoles": ["edams-admin"],
      "clientRoles": {
        "edams-client": ["admin"]
      }
    },
    {
      "name": "/edams-users",
      "path": "/edams-users",
      "subGroups": [],
      "attributes": {},
      "realmRoles": ["edams-user"],
      "clientRoles": {
        "edams-client": ["user"]
      }
    },
    {
      "name": "/edams-stewards",
      "path": "/edams-stewards",
      "subGroups": [],
      "attributes": {},
      "realmRoles": ["edams-data-steward"],
      "clientRoles": {
        "edams-client": ["data-steward"]
      }
    },
    {
      "name": "/edams-auditors",
      "path": "/edams-auditors",
      "subGroups": [],
      "attributes": {},
      "realmRoles": ["edams-auditor"],
      "clientRoles": {
        "edams-client": ["viewer"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "edams-client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:8000/login/oauth2/code/keycloak",
        "http://localhost:3000/login/oauth2/code/keycloak",
        "http://localhost:8080/login/oauth2/code/keycloak",
        "https://edams.company.com/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:3000",
        "http://localhost:8080",
        "https://edams.company.com"
      ],
      "attributes": {
        "access.token.lifespan": "7200",
        "access.token.lifespan.for.implicit.flow.integrated": "900",
        "saml.assertion.lifespan": "600",
        "saml.client.signature": "false",
        "saml.server.signature": "false",
        "saml.signing.certificate": "",
        "saml.signing.private.key": "",
        "backchannel.logout.revoke.offline.tokens": "false",
        "backchannel.logout.url": "",
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "client.secret.creation.time": "${CLIENT_SECRET_CREATION_TIME}",
        "token.response.type.bearer": "true"
      },
      "authenticationFlowBindingOverrides": {
        "browser": "${BROWSER_FLOW_ID}",
        "direct_grant": "${DIRECT_GRANT_FLOW_ID}"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "edams-roles"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "access": {
        "view": true,
        "configure": true,
        "manage": true
      }
    },
    {
      "clientId": "edams-backend",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${KEYCLOAK_BACKEND_SECRET}",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": false,
      "attributes": {
        "access.token.lifespan": "300"
      },
      "access": {
        "view": true,
        "configure": true,
        "manage": true
      }
    }
  ],
  "clientScopes": [
    {
      "name": "edams-roles",
      "description": "EDAMS specific roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.type": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "realm_access.roles",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "resource_access.${client_id}.roles",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.type": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${profileScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "preferred username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.type": "true",
        "display.on.consent.screen": "true",
        "consent.screen.text": "${emailScopeConsentText}"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    }
  ],
  "scopeMappings": [
    {
      "clientScope": "offline_access",
      "roles": ["offline_access"]
    }
  ],
  "smtpServer": {
    "from": "${MAIL_FROM}",
    "host": "${MAIL_HOST}",
    "port": "${MAIL_PORT}",
    "fromDisplayName": "EDAMS System",
    "starttls": "true",
    "auth": "true",
    "user": "${MAIL_USERNAME}",
    "password": "${MAIL_PASSWORD}"
  },
  "loginTheme": "keycloak",
  "accountTheme": "keycloak",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",
  "browserSecurityHeaders": {
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "SAMEORIGIN",
    "xRobotsTag": "none",
    "xFrameOptions": "SAMEORIGIN",
    "xXSSProtection": "1; mode=block",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "attributes": {
    "cibaBackchannelTokenDeliveryMode": "poll",
    "cibaExpiresIn": "120",
    "cibaAuthRequestedUserHint": "login_hint",
    "oauth2DeviceCodeLifespan": "600",
    "clientOfflineSessionMaxLifespan": "0",
    "clientSessionIdleTimeout": "0",
    "clientSessionMaxLifespan": "0",
    "parRequestUriLifespan": "60",
    "accesTokenLifespan": "7200",
    "accesTokenLifespanForImplicitFlow": "900",
    "ssoSessionIdleTimeout": "1800",
    "ssoSessionMaxLifespan": "36000",
    "offlineSessionIdleTimeout": "2592000",
    "offlineSessionMaxLifespan": "5184000",
    "clientOfflineSessionIdleTimeout": "0"
  },
  "keycloakVersion": "23.0",
  "userManagedAccessAllowed": false
}
