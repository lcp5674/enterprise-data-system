# SkyWalking Agent Configuration for EDAMS
agent.service_name=${SW_AGENT_NAME:governance-engine}
collector.backend_service=${SW_AGENT_COLLECTOR_BACKEND_SERVICES:localhost:11800}
agent.namespace=edams
agent.instance_name=${HOSTNAME:default-instance}
agent.collector.backend_graphql=${SW_COLLECTOR_GRAPHQL:localhost:12800}
logging.level=INFO
logging.file_name=skywalking-api.log
plugin.jdbc.trace_sql_parameters=true
plugin.redis.trace_parameters=true
plugin.kafka.trace_kafka_enable=true
plugin.httpclient.trace_http_headers=true
plugin.mongodb.trace_parameters=true
