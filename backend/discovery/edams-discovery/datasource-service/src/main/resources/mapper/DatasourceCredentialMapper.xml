<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enterprise.edams.datasource.repository.DatasourceCredentialRepository">

    <resultMap id="BaseResultMap" type="com.enterprise.edams.datasource.entity.DatasourceCredential">
        <id column="id" property="id"/>
        <result column="datasource_id" property="datasourceId"/>
        <result column="credential_type" property="credentialType"/>
        <result column="key_store_name" property="keyStoreName"/>
        <result column="key_identifier" property="keyIdentifier"/>
        <result column="key_version" property="keyVersion"/>
        <result column="status" property="status"/>
        <result column="expire_time" property="expireTime"/>
        <result column="last_rotated_time" property="lastRotatedTime"/>
        <result column="next_rotation_time" property="nextRotationTime"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByDatasourceId" resultMap="BaseResultMap">
        SELECT * FROM datasource_credential
        WHERE datasource_id = #{datasourceId} AND deleted = 0
        ORDER BY created_time DESC
    </select>

    <select id="selectValidByDatasourceId" resultMap="BaseResultMap">
        SELECT * FROM datasource_credential
        WHERE datasource_id = #{datasourceId} AND status = 'ACTIVE' AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByKeyIdentifier" resultMap="BaseResultMap">
        SELECT * FROM datasource_credential
        WHERE key_identifier = #{keyIdentifier} AND deleted = 0
    </select>

    <select id="selectCredentialsNeedRotation" resultMap="BaseResultMap">
        SELECT * FROM datasource_credential
        WHERE status = 'ACTIVE' 
        AND deleted = 0 
        AND next_rotation_time IS NOT NULL 
        AND next_rotation_time &lt;= NOW()
        ORDER BY next_rotation_time ASC
    </select>

</mapper>
