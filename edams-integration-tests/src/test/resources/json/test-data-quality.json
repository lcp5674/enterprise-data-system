{
  "qualityRules": [
    {
      "id": 1,
      "name": "Customer Email Not Null",
      "ruleType": "NOT_NULL",
      "assetId": 1,
      "expression": "email IS NOT NULL",
      "threshold": 99.5,
      "status": "ACTIVE"
    },
    {
      "id": 2,
      "name": "Customer Email Format",
      "ruleType": "REGEX",
      "assetId": 1,
      "expression": "email ~* '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'",
      "threshold": 98.0,
      "status": "ACTIVE"
    },
    {
      "id": 3,
      "name": "Order Amount Range",
      "ruleType": "RANGE",
      "assetId": 2,
      "expression": "amount > 0 AND amount < 1000000",
      "threshold": 100.0,
      "status": "ACTIVE"
    },
    {
      "id": 4,
      "name": "Order Date Validity",
      "ruleType": "CUSTOM",
      "assetId": 2,
      "expression": "order_date <= CURRENT_DATE",
      "threshold": 100.0,
      "status": "ACTIVE"
    },
    {
      "id": 5,
      "name": "Product SKU Unique",
      "ruleType": "UNIQUE",
      "assetId": 3,
      "expression": "COUNT(*) = COUNT(DISTINCT sku)",
      "threshold": 100.0,
      "status": "ACTIVE"
    }
  ],
